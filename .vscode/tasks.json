{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Raylib 64bit",
            "type": "shell",
            "command": "C:/w64devkit/bin/gcc.exe",
            "args": [
                "${file}",
                "-o", "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-I", "C:/raylib-6.0_win64_mingw-w64/include",
                "-L", "C:/raylib-6.0_win64_mingw-w64/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-lpthread"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}